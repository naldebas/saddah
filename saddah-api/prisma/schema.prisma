// SADDAH CRM Database Schema
// Version: 1.0.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// TENANT & AUTH
// ============================================

model Tenant {
  id        String   @id @default(uuid())
  name      String
  domain    String?  @unique
  settings  Json     @default("{}")
  plan      String   @default("trial")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users          User[]
  contacts       Contact[]
  companies      Company[]
  deals          Deal[]
  leads          Lead[]
  activities     Activity[]
  conversations  Conversation[]
  pipelines      Pipeline[]
  whatsAppConfig WhatsAppConfig?
  projects       Project[]

  @@map("tenants")
}

model User {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  managerId    String?   @map("manager_id")
  email        String
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  phone        String?
  avatar       String?
  role         String    @default("sales_rep")
  language     String    @default("ar")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant                Tenant         @relation(fields: [tenantId], references: [id])
  manager               User?          @relation("UserManager", fields: [managerId], references: [id])
  teamMembers           User[]         @relation("UserManager")
  ownedCompanies        Company[]      @relation("CompanyOwner")
  ownedContacts         Contact[]      @relation("ContactOwner")
  ownedDeals            Deal[]         @relation("DealOwner")
  ownedLeads            Lead[]         @relation("LeadOwner")
  activities            Activity[]     @relation("ActivityCreator")
  assignedConversations Conversation[] @relation("ConversationAssignee")
  refreshTokens         RefreshToken[]
  notifications         Notification[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([managerId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ============================================
// CRM ENTITIES
// ============================================

model Contact {
  id        String  @id @default(uuid())
  tenantId  String  @map("tenant_id")
  ownerId   String  @map("owner_id")
  companyId String? @map("company_id")
  leadId    String? @map("lead_id") // Link to original lead

  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  email        String?
  phone        String?
  whatsapp     String?
  title        String?
  source       String   @default("manual")
  tags         String[] @default([])
  customFields Json     @default("{}") @map("custom_fields")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  owner         User           @relation("ContactOwner", fields: [ownerId], references: [id])
  company       Company?       @relation(fields: [companyId], references: [id])
  lead          Lead?          @relation(fields: [leadId], references: [id])
  deals         Deal[]
  activities    Activity[]
  conversations Conversation[]

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, phone])
  @@index([tenantId, ownerId])
  @@index([tenantId, leadId])
  @@map("contacts")
}

model Company {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  ownerId  String @map("owner_id")

  name         String
  industry     String?
  website      String?
  phone        String?
  email        String?
  address      String?
  city         String?
  country      String   @default("SA")
  size         String?
  tags         String[] @default([])
  customFields Json     @default("{}") @map("custom_fields")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  owner    User      @relation("CompanyOwner", fields: [ownerId], references: [id])
  contacts Contact[]
  deals    Deal[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, ownerId])
  @@map("companies")
}

model Pipeline {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  stages PipelineStage[]
  deals  Deal[]

  @@index([tenantId])
  @@map("pipelines")
}

model PipelineStage {
  id          String   @id @default(uuid())
  pipelineId  String   @map("pipeline_id")
  name        String
  order       Int
  probability Int      @default(0)
  color       String   @default("#6B7280")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@index([pipelineId])
  @@map("pipeline_stages")
}

model Deal {
  id         String  @id @default(uuid())
  tenantId   String  @map("tenant_id")
  ownerId    String  @map("owner_id")
  contactId  String? @map("contact_id")
  companyId  String? @map("company_id")
  pipelineId String  @map("pipeline_id")
  stageId    String  @map("stage_id")
  productId  String? @map("product_id") // Link to a specific property unit

  title             String
  value             Decimal   @db.Decimal(15, 2)
  currency          String    @default("SAR")
  probability       Int       @default(0)
  expectedCloseDate DateTime? @map("expected_close_date")
  closedAt          DateTime? @map("closed_at")
  status            String    @default("open")
  lostReason        String?   @map("lost_reason")
  tags              String[]  @default([])
  customFields      Json      @default("{}") @map("custom_fields")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant     Tenant        @relation(fields: [tenantId], references: [id])
  owner      User          @relation("DealOwner", fields: [ownerId], references: [id])
  contact    Contact?      @relation(fields: [contactId], references: [id])
  company    Company?      @relation(fields: [companyId], references: [id])
  pipeline   Pipeline      @relation(fields: [pipelineId], references: [id])
  stage      PipelineStage @relation(fields: [stageId], references: [id])
  product    Product?      @relation(fields: [productId], references: [id])
  activities Activity[]

  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@index([tenantId, stageId])
  @@index([tenantId, status])
  @@index([tenantId, contactId])
  @@index([tenantId, companyId])
  @@index([tenantId, pipelineId])
  @@index([tenantId, productId])
  @@index([tenantId, createdAt])
  @@index([tenantId, closedAt])
  @@map("deals")
}

// ============================================
// LEADS
// ============================================

model Lead {
  id        String  @id @default(uuid())
  tenantId  String  @map("tenant_id")
  ownerId   String? @map("owner_id")
  contactId String? @map("contact_id") // Link to contact created from this lead
  projectId String? @map("project_id") // Interested project from bot

  firstName            String    @map("first_name")
  lastName             String?   @map("last_name")
  email                String?
  phone                String?
  whatsapp             String?
  source               String    @default("manual")
  sourceId             String?   @map("source_id")
  status               String    @default("new")
  score                Int       @default(0)
  scoreGrade           String?   @map("score_grade")
  propertyType         String?   @map("property_type")
  budget               Decimal?  @db.Decimal(15, 2)
  timeline             String?
  location             String?
  financingNeeded      Boolean?  @map("financing_needed")
  convertedAt          DateTime? @map("converted_at")
  convertedToContactId String?   @map("converted_to_contact_id")
  convertedToDealId    String?   @map("converted_to_deal_id")
  notes                String?
  tags                 String[]  @default([])
  customFields         Json      @default("{}") @map("custom_fields")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  tenant             Tenant                  @relation(fields: [tenantId], references: [id])
  owner              User?                   @relation("LeadOwner", fields: [ownerId], references: [id])
  project            Project?                @relation(fields: [projectId], references: [id])
  contacts           Contact[]
  scoreHistory       LeadScoreHistory[]
  productSuggestions LeadProductSuggestion[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, score])
  @@index([tenantId, ownerId])
  @@index([tenantId, createdAt])
  @@index([tenantId, sourceId])
  @@index([tenantId, contactId])
  @@index([tenantId, projectId])
  @@map("leads")
}

model LeadScoreHistory {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  score     Int
  grade     String
  factors   Json
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_score_history")
}

// ============================================
// ACTIVITIES
// ============================================

model Activity {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  createdById String  @map("created_by_id")
  contactId   String? @map("contact_id")
  dealId      String? @map("deal_id")

  type        String
  subject     String?
  description String?
  dueDate     DateTime? @map("due_date")
  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at")
  duration    Int?
  outcome     String?
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdBy User     @relation("ActivityCreator", fields: [createdById], references: [id])
  contact   Contact? @relation(fields: [contactId], references: [id])
  deal      Deal?    @relation(fields: [dealId], references: [id])

  @@index([tenantId])
  @@index([tenantId, contactId])
  @@index([tenantId, dealId])
  @@index([tenantId, type])
  @@index([tenantId, dueDate])
  @@index([tenantId, createdById])
  @@index([tenantId, createdById, isCompleted])
  @@index([tenantId, createdAt])
  @@map("activities")
}

// ============================================
// CONVERSATIONS
// ============================================

model Conversation {
  id           String  @id @default(uuid())
  tenantId     String  @map("tenant_id")
  contactId    String? @map("contact_id")
  assignedToId String? @map("assigned_to_id")

  channel           String
  channelId         String    @map("channel_id")
  status            String    @default("bot")
  qualificationData Json      @default("{}") @map("qualification_data")
  lastMessageAt     DateTime? @map("last_message_at")
  closedAt          DateTime? @map("closed_at")
  closedReason      String?   @map("closed_reason")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  contact    Contact?  @relation(fields: [contactId], references: [id])
  assignedTo User?     @relation("ConversationAssignee", fields: [assignedToId], references: [id])
  messages   Message[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, channelId])
  @@index([tenantId, assignedToId])
  @@index([tenantId, contactId])
  @@map("conversations")
}

model Message {
  id             String @id @default(uuid())
  conversationId String @map("conversation_id")

  direction     String
  sender        String
  type          String   @default("text")
  content       String
  mediaUrl      String?  @map("media_url")
  transcription String?
  duration      Int?
  externalId    String?  @map("external_id")
  status        String   @default("sent")
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([externalId])
  @@map("messages")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  userId   String @map("user_id")

  type      String
  title     String
  message   String
  data      Json     @default("{}")
  isRead    Boolean  @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([tenantId])
  @@map("notifications")
}

// ============================================
// WHATSAPP CONFIGURATION
// ============================================

model WhatsAppConfig {
  id            String   @id @default(uuid())
  tenantId      String   @unique @map("tenant_id")
  provider      String   @default("twilio") // 'twilio' or 'meta'
  phoneNumber   String?  @map("phone_number")
  credentials   String   // Encrypted JSON containing API keys
  webhookSecret String   @map("webhook_secret")
  isActive      Boolean  @default(false) @map("is_active")
  isVerified    Boolean  @default(false) @map("is_verified")
  lastTestedAt  DateTime? @map("last_tested_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("whatsapp_configs")
}

model WhatsAppQuotaUsage {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")

  // Daily tracking
  dailyCount    Int      @default(0) @map("daily_count")
  dailyDate     DateTime @map("daily_date") @db.Date

  // Monthly tracking
  monthlyCount  Int      @default(0) @map("monthly_count")
  monthYear     String   @map("month_year") // Format: YYYY-MM

  // Limits (can be overridden per tenant)
  dailyLimit    Int      @default(1000) @map("daily_limit")
  monthlyLimit  Int      @default(10000) @map("monthly_limit")

  // Warnings sent
  warning80Sent Boolean  @default(false) @map("warning_80_sent")
  warning90Sent Boolean  @default(false) @map("warning_90_sent")
  warning100Sent Boolean @default(false) @map("warning_100_sent")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, dailyDate])
  @@unique([tenantId, monthYear])
  @@index([tenantId])
  @@map("whatsapp_quota_usage")
}

model WhatsAppTemplate {
  id         String @id @default(uuid())
  tenantId   String @map("tenant_id")
  externalId String @map("external_id") // ID from WhatsApp/Meta

  name       String
  language   String   @default("ar")
  category   String   // MARKETING, UTILITY, AUTHENTICATION
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED

  // Template structure
  components Json     @default("[]") // Header, body, footer, buttons

  // Example content for preview
  headerText   String?  @map("header_text")
  bodyText     String   @map("body_text")
  footerText   String?  @map("footer_text")

  // Variable placeholders count
  variableCount Int    @default(0) @map("variable_count")

  // Meta info
  rejectionReason String?  @map("rejection_reason")
  qualityScore    String?  @map("quality_score") // GREEN, YELLOW, RED
  lastSyncedAt    DateTime? @map("last_synced_at")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, name, language])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, category])
  @@map("whatsapp_templates")
}

// ============================================
// BOTPRESS INTEGRATION
// ============================================

model BotpressConfig {
  id                     String    @id @default(uuid())
  tenantId               String    @unique @map("tenant_id")
  botId                  String    @map("bot_id")
  workspaceId            String    @map("workspace_id")
  credentials            String    // Encrypted: { token, webhookSecret }
  webhookUrl             String    @map("webhook_url") // Botpress webhook URL
  callbackUrl            String    @map("callback_url") // Saddah callback URL for Botpress events
  isActive               Boolean   @default(false) @map("is_active")
  isVerified             Boolean   @default(false) @map("is_verified")
  autoCreateLead         Boolean   @default(true) @map("auto_create_lead")
  autoConvertDeal        Boolean   @default(true) @map("auto_convert_deal")
  qualificationThreshold Int       @default(60) @map("qualification_threshold")
  defaultPipelineId      String?   @map("default_pipeline_id")
  lastTestedAt           DateTime? @map("last_tested_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("botpress_configs")
}

model BotpressConversation {
  id                 String   @id @default(uuid())
  tenantId           String   @map("tenant_id")
  conversationId     String   @map("conversation_id") // Saddah conversation ID
  botpressConvId     String   @map("botpress_conv_id") // Botpress conversation ID
  botpressState      String?  @map("botpress_state") // Current flow state
  qualificationData  Json     @default("{}") @map("qualification_data")
  qualificationScore Int      @default(0) @map("qualification_score")
  lastSyncedAt       DateTime @map("last_synced_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, conversationId])
  @@index([tenantId])
  @@index([botpressConvId])
  @@map("botpress_conversations")
}

// ============================================
// PROJECTS & PRODUCTS (Real Estate)
// ============================================

model Project {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String   // اسم المشروع
  city        String   // المدينة
  district    String?  // الحي
  type        String   // residential, commercial, mixed
  description String?  @db.Text
  totalUnits  Int      @default(0) @map("total_units")
  status      String   @default("active") // active, coming_soon, sold_out
  images      Json     @default("[]")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]
  leads    Lead[]

  @@index([tenantId])
  @@index([tenantId, city])
  @@index([tenantId, district])
  @@index([tenantId, status])
  @@index([tenantId, type, status])
  @@map("projects")
}

model Product {
  id         String  @id @default(uuid())
  tenantId   String  @map("tenant_id")
  projectId  String  @map("project_id")
  unitNumber String  @map("unit_number") // رقم الوحدة
  type       String  // villa, apartment, townhouse, floor, land
  area       Decimal @db.Decimal(10, 2) // المساحة
  bedrooms   Int?    // الغرف
  bathrooms  Int?    // الحمامات
  floor      Int?    // الطابق
  price      Decimal @db.Decimal(15, 2) // السعر
  currency   String  @default("SAR")
  status     String  @default("available") // available, reserved, sold
  features   String[] @default([])
  images     Json     @default("[]")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  project     Project                 @relation(fields: [projectId], references: [id])
  deals       Deal[]
  suggestions LeadProductSuggestion[]

  @@unique([projectId, unitNumber])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, price])
  @@index([projectId])
  @@map("products")
}

model LeadProductSuggestion {
  id          String   @id @default(uuid())
  leadId      String   @map("lead_id")
  productId   String   @map("product_id")
  matchScore  Int      @default(0) @map("match_score") // نسبة التطابق 0-100
  matchReason Json     @default("{}") @map("match_reason")
  status      String   @default("suggested") // suggested, viewed, interested, rejected
  suggestedAt DateTime @default(now()) @map("suggested_at")

  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([leadId, productId])
  @@index([leadId])
  @@index([productId])
  @@map("lead_product_suggestions")
}
