# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/saddah_dev?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Throttling
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Swagger
SWAGGER_ENABLED=true

# OpenAI / LLM Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo
OPENAI_FALLBACK_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT=30000

# Context Configuration
CONTEXT_MAX_TOKENS=4000
CONTEXT_RESERVE_TOKENS=500
MAX_CONVERSATION_LENGTH=100
SUMMARY_THRESHOLD=20

# WhatsApp Configuration
# Provider: 'twilio' or 'meta'
WHATSAPP_PROVIDER=twilio
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token-change-in-production
# Skip signature verification in development (NEVER enable in production!)
WHATSAPP_SKIP_SIGNATURE_VERIFICATION=false

# Twilio Configuration (if WHATSAPP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=+14155238886

# Meta Business API Configuration (if WHATSAPP_PROVIDER=meta)
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_BUSINESS_ACCOUNT_ID=
META_APP_SECRET=

# WhatsApp Bot Settings
WHATSAPP_BOT_ENABLED=true
# Default tenant ID for WhatsApp messages (in production, this is determined dynamically)
DEFAULT_TENANT_ID=
WHATSAPP_BOT_GREETING=مرحباً! أنا مساعدك الآلي من صداح. كيف يمكنني مساعدتك اليوم؟
WHATSAPP_HUMAN_HANDOFF_KEYWORDS=مساعدة,موظف,بشري,help,agent
WHATSAPP_MAX_BOT_RETRIES=3
WHATSAPP_RETRY_DELAY_MS=1000

# Message Queue Configuration
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6379
BULL_REDIS_PASSWORD=
