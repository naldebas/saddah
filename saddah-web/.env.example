# Saddah CRM Frontend Environment Configuration

# ===========================================
# API Configuration
# ===========================================
# Base URL for the API server
VITE_API_BASE_URL=/api/v1

# API request timeout in milliseconds
VITE_API_TIMEOUT=30000

# ===========================================
# App Configuration
# ===========================================
# Application name
VITE_APP_NAME=Saddah CRM

# Application version
VITE_APP_VERSION=1.0.0

# Environment: development, staging, production
VITE_APP_ENVIRONMENT=development

# ===========================================
# Feature Flags
# ===========================================
# Enable mock data for development
VITE_ENABLE_MOCK_DATA=false

# Enable debug mode (shows console logs, dev tools, etc.)
VITE_ENABLE_DEBUG_MODE=true

# Enable analytics tracking
VITE_ENABLE_ANALYTICS=false

# ===========================================
# External Services (Optional)
# ===========================================
# WhatsApp Business API URL
# VITE_WHATSAPP_API_URL=

# Google Maps API Key (for location features)
# VITE_GOOGLE_MAPS_API_KEY=

# Sentry DSN for error tracking
# VITE_SENTRY_DSN=

# ===========================================
# WebSocket Configuration
# ===========================================
# WebSocket server URL for real-time updates
# VITE_WS_URL=ws://localhost:3001

# Reconnection interval in milliseconds
VITE_WS_RECONNECT_INTERVAL=5000
